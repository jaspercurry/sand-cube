{
  "provenanceOutput": "build/workbench/joint_coupon/snapshot-job-provenance.json",
  "jobs": [
    {
      "input": "build/workbench/joint_coupon/joint_coupon_assembly.step",
      "mode": "view",
      "display": {
        "mode": "solid",
        "projection": "orthographic"
      },
      "outputs": [
        {
          "path": "build/workbench/joint_coupon/snapshot-isometric.png",
          "camera": "iso"
        }
      ],
      "render": {
        "padding": 0.12,
        "sizeProfile": "diagnostic",
        "viewLabels": true
      }
    },
    {
      "input": "build/workbench/joint_coupon/joint_coupon_assembly.step",
      "mode": "section",
      "section": {
        "plane": "YZ",
        "offset": 0.0
      },
      "outputs": [
        {
          "path": "build/workbench/joint_coupon/snapshot-joint-section.png"
        }
      ],
      "render": {
        "padding": 0.12,
        "sizeProfile": "section",
        "viewLabels": true
      }
    }
  ]
}
